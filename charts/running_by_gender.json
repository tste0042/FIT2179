{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Running and jogging participation by gender.",
  "width": 420,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/refs/heads/main/data/running_by_demographic.csv"
  },
  "transform": [
    {
      "filter": "datum.group_type == 'Gender'"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "color": "#1f6f8b"
  },
  "encoding": {
    "x": {
      "field": "group",
      "type": "nominal",
      "title": "Gender",
      "sort": [
        "Male",
        "Female"
      ]
    },
    "y": {
      "field": "participation_rate",
      "type": "quantitative",
      "title": "Participation rate (%)"
    },
    "tooltip": [
      {
        "field": "group",
        "type": "nominal",
        "title": "Gender"
      },
      {
        "field": "participants",
        "type": "quantitative",
        "format": ",",
        "title": "Participants"
      },
      {
        "field": "participation_rate",
        "type": "quantitative",
        "format": ".2f",
        "title": "Participation rate (%)"
      }
    ]
  },
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#e8edf2",
      "domainColor": "#b8c3cf",
      "tickColor": "#b8c3cf"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "view": {
      "stroke": null
    }
  }
}