{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Average monthly maximum temperature by Australian capital city.",
  "width": 560,
  "height": 330,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/main/data/city_temperature.csv"
  },
  "params": [
    {
      "name": "City_selection",
      "bind": {
        "input": "select",
        "options": [
          null,
          "Adelaide",
          "Brisbane",
          "Canberra",
          "Darwin",
          "Hobart",
          "Melbourne",
          "Perth",
          "Sydney"
        ],
        "labels": [
          "Show all",
          "Adelaide",
          "Brisbane",
          "Canberra",
          "Darwin",
          "Hobart",
          "Melbourne",
          "Perth",
          "Sydney"
        ],
        "name": "Highlight city: "
      }
    }
  ],
  "transform": [
    {
      "calculate": "City_selection == null || datum.city == City_selection ? 'Selected' : 'Other'",
      "as": "selection_status"
    }
  ],
  "mark": {
    "type": "rect",
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "x": {
  "field": "month",
  "type": "ordinal",
  "sort": [
    "January",
    "February",
    "March",
    "April",
    "May",
    "June",
    "July",
    "August",
    "September",
    "October",
    "November",
    "December"
  ],
  "title": null,
  "axis": {
    "labelAngle": -35
  }
},
    "y": {
      "field": "city",
      "type": "nominal",
      "title": null,
      "sort": [
        "Darwin",
        "Brisbane",
        "Sydney",
        "Perth",
        "Adelaide",
        "Melbourne",
        "Canberra",
        "Hobart"
      ]
    },
    "color": {
      "field": "avg_max_temp_c",
      "type": "quantitative",
      "title": "Avg max temp (°C)",
      "scale": {
        "domain": [
          10,
          35
        ],
        "range": [
          "#d7eff5",
          "#f7f3b2",
          "#f4a261",
          "#d94841"
        ]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "gradientLength": 200
      }
    },
    "opacity": {
      "condition": {
        "test": "City_selection == null || datum.city == City_selection",
        "value": 1
      },
      "value": 0.35
    },
    "tooltip": [
      {
        "field": "city",
        "type": "nominal",
        "title": "City"
      },
      {
        "field": "month",
        "type": "ordinal",
        "title": "Month"
      },
      {
        "field": "avg_max_temp_c",
        "type": "quantitative",
        "format": ".1f",
        "title": "Avg max temp (°C)"
      },
      {
        "field": "running_temp_category",
        "type": "nominal",
        "title": "Running condition"
      }
    ]
  },
  "config": {
  "background": "transparent",
  "font": "Inter, Arial, sans-serif",
  "view": {
    "stroke": null
  },
  "axis": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "gridColor": "#e8edf2",
    "domainColor": "#c8d3dd",
    "tickColor": "#c8d3dd"
  },
  "legend": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "orient": "bottom"
  },
  "title": {
    "font": "Inter, Arial, sans-serif",
    "fontSize": 14,
    "fontWeight": 800,
    "anchor": "start",
    "color": "#132033"
  },
  "bar": {
    "cornerRadiusEnd": 5
  },
  "point": {
    "filled": true
  }
}
}
