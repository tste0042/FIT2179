{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Monthly average maximum temperature by capital city.",
  "width": 760,
  "height": 310,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/refs/heads/main/data/city_temperature.csv"
  },
  "mark": "rect",
  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal",
      "sort": [
        "January",
        "February",
        "March",
        "April",
        "May",
        "June",
        "July",
        "August",
        "September",
        "October",
        "November",
        "December"
      ],
      "title": "Month"
    },
    "y": {
      "field": "city",
      "type": "nominal",
      "title": "City"
    },
    "color": {
      "field": "avg_max_temp_c",
      "type": "quantitative",
      "title": "Avg max temp (\u00b0C)",
      "scale": {
        "scheme": "yelloworangered"
      }
    },
    "tooltip": [
      {
        "field": "city",
        "type": "nominal",
        "title": "City"
      },
      {
        "field": "month",
        "type": "ordinal",
        "title": "Month"
      },
      {
        "field": "avg_max_temp_c",
        "type": "quantitative",
        "format": ".1f",
        "title": "Avg max temp (\u00b0C)"
      },
      {
        "field": "running_temp_category",
        "type": "nominal",
        "title": "Running category"
      }
    ]
  },
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#e8edf2",
      "domainColor": "#b8c3cf",
      "tickColor": "#b8c3cf"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "view": {
      "stroke": null
    }
  }
}