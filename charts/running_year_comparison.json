{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Running/jogging adult participation in 2024 and 2025.",
  "width": 420,
  "height": 260,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/main/data/running_year_comparison.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "color": "#1f6f8b"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "participants",
      "type": "quantitative",
      "title": "Estimated adult participants",
      "axis": {
        "format": "~s"
      }
    },
    "tooltip": [
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "participants",
        "type": "quantitative",
        "format": ",",
        "title": "Participants"
      },
      {
        "field": "participation_rate",
        "type": "quantitative",
        "format": ".2f",
        "title": "Participation rate (%)"
      }
    ]
  },
  "config": {
  "background": "transparent",
  "font": "Inter, Arial, sans-serif",
  "view": {
    "stroke": null
  },
  "axis": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "gridColor": "#e8edf2",
    "domainColor": "#c8d3dd",
    "tickColor": "#c8d3dd"
  },
  "legend": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "orient": "bottom"
  },
  "title": {
    "font": "Inter, Arial, sans-serif",
    "fontSize": 14,
    "fontWeight": 800,
    "anchor": "start",
    "color": "#132033"
  },
  "bar": {
    "cornerRadiusEnd": 5
  },
  "point": {
    "filled": true
  }
}
}
