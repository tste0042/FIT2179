{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Running/jogging adult participation in 2024 and 2025.",
  "width": 420,
  "height": 260,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/refs/heads/main/data/running_year_comparison.csv"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "participants",
      "type": "quantitative",
      "title": "Estimated adult participants",
      "axis": {
        "format": "~s"
      }
    },
    "tooltip": [
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "participants",
        "type": "quantitative",
        "format": ",",
        "title": "Participants"
      },
      {
        "field": "participation_rate",
        "type": "quantitative",
        "format": ".2f",
        "title": "Participation rate (%)"
      }
    ]
  },
  "config": {
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#e8edf2"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "view": {
      "stroke": null
    }
  }
}
