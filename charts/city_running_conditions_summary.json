{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Number of comfortable running-temperature months by capital city.",
  "width": 680,
  "height": 280,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/main/data/city_running_conditions_summary.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "color": "#1f6f8b"
  },
  "encoding": {
    "y": {
      "field": "city",
      "type": "nominal",
      "sort": {
        "field": "comfortable_months",
        "order": "descending"
      },
      "title": null
    },
    "x": {
      "field": "comfortable_months",
      "type": "quantitative",
      "title": "Comfortable months"
    },
    "tooltip": [
      {
        "field": "city",
        "type": "nominal",
        "title": "City"
      },
      {
        "field": "comfortable_months",
        "type": "quantitative",
        "title": "Comfortable months"
      },
      {
        "field": "hot_months",
        "type": "quantitative",
        "title": "Hot months"
      },
      {
        "field": "avg_annual_max_temp_c",
        "type": "quantitative",
        "format": ".1f",
        "title": "Avg annual max temp (\u00b0C)"
      }
    ]
  },
  "config": {
  "background": "transparent",
  "font": "Inter, Arial, sans-serif",
  "view": {
    "stroke": null
  },
  "axis": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "gridColor": "#e8edf2",
    "domainColor": "#c8d3dd",
    "tickColor": "#c8d3dd"
  },
  "legend": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "orient": "bottom"
  },
  "title": {
    "font": "Inter, Arial, sans-serif",
    "fontSize": 14,
    "fontWeight": 800,
    "anchor": "start",
    "color": "#132033"
  },
  "bar": {
    "cornerRadiusEnd": 5
  },
  "point": {
    "filled": true
  }
}
}
