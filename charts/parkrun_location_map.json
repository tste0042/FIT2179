{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Australian standard 5km parkrun locations.",
  "width": 480,
  "height": 360,
  "projection": {
    "type": "equirectangular",
    "center": [
      134,
      -26
    ],
    "scale": 560
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/tste0042/FIT2179/refs/heads/main/data/aus_states_simplified.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eeeeee",
        "stroke": "white",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/tste0042/FIT2179/refs/heads/main/data/parkrun_locations.csv"
      },
      "mark": {
        "type": "circle",
        "opacity": 0.55,
        "size": 18
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "event_name",
            "type": "nominal",
            "title": "Event"
          },
          {
            "field": "state_abbrev",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "event_location",
            "type": "nominal",
            "title": "Location"
          }
        ]
      }
    }
  ],
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#e8edf2",
      "domainColor": "#b8c3cf",
      "tickColor": "#b8c3cf"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "view": {
      "stroke": null
    }
  }
}