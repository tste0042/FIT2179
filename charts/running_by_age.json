{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Running and jogging participation by adult age group.",
  "width": 480,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/main/data/running_by_demographic.csv"
  },
  "transform": [
    {
      "filter": "datum.group_type == 'Age'"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "color": "#1f6f8b"
  },
  "encoding": {
    "x": {
      "field": "group",
      "type": "ordinal",
      "title": "Age group",
      "sort": [
        "15-17",
        "18-24",
        "25-34",
        "35-44",
        "45-54",
        "55-64",
        "65+"
      ]
    },
    "y": {
      "field": "participation_rate",
      "type": "quantitative",
      "title": "Participation rate (%)"
    },
    "tooltip": [
      {
        "field": "group",
        "type": "ordinal",
        "title": "Age group"
      },
      {
        "field": "participants",
        "type": "quantitative",
        "format": ",",
        "title": "Participants"
      },
      {
        "field": "participation_rate",
        "type": "quantitative",
        "format": ".2f",
        "title": "Participation rate (%)"
      }
    ]
  },
  "config": {
  "background": "transparent",
  "font": "Inter, Arial, sans-serif",
  "view": {
    "stroke": null
  },
  "axis": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "gridColor": "#e8edf2",
    "domainColor": "#c8d3dd",
    "tickColor": "#c8d3dd"
  },
  "legend": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "orient": "bottom"
  },
  "title": {
    "font": "Inter, Arial, sans-serif",
    "fontSize": 14,
    "fontWeight": 800,
    "anchor": "start",
    "color": "#132033"
  },
  "bar": {
    "cornerRadiusEnd": 5
  },
  "point": {
    "filled": true
  }
}
}
