{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Top adult physical activities in Australia by estimated participants.",
  "width": "container",
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/2179/refs/heads/main/Datasets/activity_rankings.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "y": {
      "field": "activity",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },
    "x": {
      "field": "participants",
      "type": "quantitative",
      "title": "Estimated adult participants",
      "axis": {
        "format": "~s"
      }
    },
    "tooltip": [
      {
        "field": "activity",
        "type": "nominal",
        "title": "Activity"
      },
      {
        "field": "participants",
        "type": "quantitative",
        "format": ",",
        "title": "Participants"
      },
      {
        "field": "participation_rate",
        "type": "quantitative",
        "format": ".2f",
        "title": "Participation rate (%)"
      }
    ]
  },
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 12,
      "titleFontSize": 12,
      "gridColor": "#e8edf2"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "title": {
      "font": "Inter, Arial, sans-serif",
      "fontSize": 16,
      "anchor": "start",
      "fontWeight": 700
    },
    "view": {
      "stroke": null
    }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  }
}
