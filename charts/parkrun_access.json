{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Parkrun events per 100,000 people by state and territory.",
  "width": 480,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/refs/heads/main/data/parkrun_access.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "color": "#1f6f8b"
  },
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": {
        "field": "events_per_100k",
        "order": "descending"
      },
      "title": null
    },
    "x": {
      "field": "events_per_100k",
      "type": "quantitative",
      "title": "Events per 100,000 people"
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State/Territory"
      },
      {
        "field": "parkrun_events",
        "type": "quantitative",
        "title": "Events"
      },
      {
        "field": "population",
        "type": "quantitative",
        "format": ",",
        "title": "Population"
      },
      {
        "field": "events_per_100k",
        "type": "quantitative",
        "format": ".2f",
        "title": "Events per 100,000"
      }
    ]
  },
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gridColor": "#e8edf2",
      "domainColor": "#b8c3cf",
      "tickColor": "#b8c3cf"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "view": {
      "stroke": null
    }
  }
}