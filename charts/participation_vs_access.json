{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Relationship between AusPlay running participation and parkrun event access.",
  "width": 450,
  "height": 340,
  "data": {
    "url": "https://raw.githubusercontent.com/tste0042/FIT2179/main/data/participation_vs_access.csv"
  },
  "params": [
    {
      "name": "State_selection",
      "bind": {
        "input": "select",
        "options": [
          null,
          "New South Wales",
          "Victoria",
          "Queensland",
          "South Australia",
          "Western Australia",
          "Tasmania",
          "Northern Territory",
          "Australian Capital Territory"
        ],
        "labels": [
          "Show all",
          "New South Wales",
          "Victoria",
          "Queensland",
          "South Australia",
          "Western Australia",
          "Tasmania",
          "Northern Territory",
          "Australian Capital Territory"
        ],
        "name": "Highlight state: "
      }
    }
  ],
  "transform": [
    {
      "calculate": "State_selection == null || datum.state == State_selection ? 'Selected' : 'Other'",
      "as": "selection_status"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": {
          "field": "events_per_100k",
          "type": "quantitative",
          "title": "Parkrun events per 100,000 people",
          "scale": {
            "zero": false,
            "nice": true
          }
        },
        "y": {
          "field": "running_participation_rate",
          "type": "quantitative",
          "title": "Running participation rate (%)",
          "scale": {
            "zero": false,
            "nice": true
          }
        },
        "size": {
          "field": "parkrun_events",
          "type": "quantitative",
          "title": "Parkrun events",
          "scale": {
            "range": [
              90,
              700
            ]
          },
          "legend": {
            "orient": "right"
          }
        },
        "color": {
          "field": "selection_status",
          "type": "nominal",
          "scale": {
            "domain": [
              "Selected",
              "Other"
            ],
            "range": [
              "#0b6b3a",
              "#86a8c7"
            ]
          },
          "legend": null
        },
        "opacity": {
          "condition": {
            "test": "State_selection == null || datum.state == State_selection",
            "value": 0.95
          },
          "value": 0.25
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "running_participation_rate",
            "type": "quantitative",
            "format": ".2f",
            "title": "Running rate (%)"
          },
          {
            "field": "events_per_100k",
            "type": "quantitative",
            "format": ".2f",
            "title": "Events per 100k people"
          },
          {
            "field": "parkrun_events",
            "type": "quantitative",
            "format": ",",
            "title": "Parkrun events"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 11,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "events_per_100k",
          "type": "quantitative"
        },
        "y": {
          "field": "running_participation_rate",
          "type": "quantitative"
        },
        "text": {
          "field": "state_abbrev",
          "type": "nominal"
        },
        "opacity": {
          "condition": {
            "test": "State_selection == null || datum.state == State_selection",
            "value": 1
          },
          "value": 0.25
        },
        "color": {
          "value": "#102a43"
        }
      }
    }
  ],
  "config": {
  "background": "transparent",
  "font": "Inter, Arial, sans-serif",
  "view": {
    "stroke": null
  },
  "axis": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "gridColor": "#e8edf2",
    "domainColor": "#c8d3dd",
    "tickColor": "#c8d3dd"
  },
  "legend": {
    "labelFont": "Inter, Arial, sans-serif",
    "titleFont": "Inter, Arial, sans-serif",
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#5b6778",
    "titleColor": "#132033",
    "orient": "bottom"
  },
  "title": {
    "font": "Inter, Arial, sans-serif",
    "fontSize": 14,
    "fontWeight": 800,
    "anchor": "start",
    "color": "#132033"
  },
  "bar": {
    "cornerRadiusEnd": 5
  },
  "point": {
    "filled": true
  }
}
}
